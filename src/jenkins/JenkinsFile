pipeline {
    agent any

    stages {
        stage("Clone repo") {
            steps {
                git branch: 'main',
                    credentialsId: 'xtremer17',
                    url: "https://github.com/xtremer15/learning-jenkins-rest-assured"
                echo "Cloning repo"
            }
        }

        stage("Build code") {
            steps {
                bat script: 'mvn compile'
            }
        }

        stage("Run Tests") {
            steps {
                bat script: 'mvn clean test'
            }
        }

     stage("Generate Allure Report") {
                steps {
                    bat script: 'mvn allure:report'
                }
            }

    }
     post {
             always {
                 script {
                     if (fileExists('target/allure-results')) {
                      echo "📢 Generating Allure report..."
                      allure includeProperties: false, results: [[path: 'target/allure-results']]
//                          junit 'target/surefire-reports/*.xml'
                     } else {
                         echo "No test results found, skipping JUnit report publishing."
                     }
                 }
             }
         }
}
